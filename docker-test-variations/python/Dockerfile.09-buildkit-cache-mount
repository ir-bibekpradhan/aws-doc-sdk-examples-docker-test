# syntax=docker/dockerfile:1
# Variation 09: BuildKit cache mount for pip
# Complexity: MEDIUM-HIGH
# Uses --mount=type=cache so pip's HTTP cache persists across builds
# dramatically speeding up repeated builds on CI.

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends gcc libffi-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /python

COPY ./python/example_code/dynamodb/requirements.txt ./requirements.txt

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt

COPY ./python/ .

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

CMD ["bash"]
