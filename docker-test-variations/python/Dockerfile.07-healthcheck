# syntax=docker/dockerfile:1
# Variation 07: HEALTHCHECK included
# Complexity: MEDIUM
# Adds a healthcheck that verifies python is callable inside the container.

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends gcc libffi-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /python

COPY ./python/example_code/dynamodb/requirements.txt ./requirements.txt

RUN pip install --no-cache-dir -r requirements.txt

COPY ./python/ .

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import boto3; print('OK')" || exit 1

CMD ["bash"]
