# syntax=docker/dockerfile:1
# Variation 07: Alpine-based minimal image
# Complexity: MEDIUM
# Uses ruby:alpine for smallest possible footprint.
# Native gem compilation requires build-base + openssl-dev.

FROM ruby:3.1.2-alpine3.16

RUN apk add --no-cache \
        build-base \
        openssl-dev \
        libffi-dev \
        git

WORKDIR /ruby

COPY ./ruby/Gemfile ./ruby/Gemfile.lock ./

RUN bundle config --delete frozen && \
    bundle install

COPY ./ruby/ .

CMD ["bash"]
