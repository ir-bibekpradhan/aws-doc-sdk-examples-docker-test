# syntax=docker/dockerfile:1
# Variation 10: Multi-stage + Non-root + HEALTHCHECK (combined high-complexity)
# Complexity: HIGH
# Demonstrates combining multiple best-practices: multi-stage build,
# non-root user, LABEL metadata, HEALTHCHECK, and slim runtime base.

# ======= Stage 1: Build =======
FROM ruby:3.1.2-buster AS builder

WORKDIR /build

COPY ./ruby/Gemfile ./ruby/Gemfile.lock ./

RUN bundle config set --local deployment 'true' && \
    bundle config set --local path 'vendor/bundle' && \
    bundle install --jobs 4 --retry 3

# ======= Stage 2: Runtime =======
FROM ruby:3.1.2-slim-buster AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd -r rubygroup \
    && useradd -r -g rubygroup -m -d /home/rubyuser rubyuser

WORKDIR /ruby

COPY --from=builder --chown=rubyuser:rubygroup /build/vendor/bundle ./vendor/bundle
COPY --chown=rubyuser:rubygroup ./ruby/ .

RUN bundle config set --local deployment 'true' && \
    bundle config set --local path 'vendor/bundle'

USER rubyuser

EXPOSE 4567

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:4567/ || exit 1

LABEL org.opencontainers.image.title="ruby-aws-sdk-examples" \
      org.opencontainers.image.source="https://github.com/awsdocs/aws-doc-sdk-examples" \
      org.opencontainers.image.licenses="Apache-2.0"

CMD ["bash"]
