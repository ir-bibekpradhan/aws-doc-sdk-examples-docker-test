# syntax=docker/dockerfile:1
# Variation 09: GraalVM Native Image
# Complexity: HIGHEST
FROM ghcr.io/graalvm/native-image-community:17 AS native-builder
WORKDIR /build
COPY ./javav2/example_code/cloudwatch/ .
RUN microdnf install -y maven -q && \
    mvn package -Dmaven.test.skip -Dcheckstyle.skip -q && \
    jar tf target/*.jar | grep '\.class' | head -20
