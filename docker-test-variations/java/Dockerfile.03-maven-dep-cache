# syntax=docker/dockerfile:1
# Variation 03: Maven dependency layer cache
# Complexity: MEDIUM
FROM maven:3.9-eclipse-temurin-17
WORKDIR /javav2/example_code/cloudwatch
# Layer 1: download deps (cache unless pom.xml changes)
COPY ./javav2/example_code/cloudwatch/pom.xml ./
RUN mvn dependency:go-offline -q
# Layer 2: compile source
COPY ./javav2/example_code/cloudwatch/ .
RUN mvn package -Dmaven.test.skip -Dcheckstyle.skip -o
CMD ["bash"]
