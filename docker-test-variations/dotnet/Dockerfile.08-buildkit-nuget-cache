# syntax=docker/dockerfile:1
# Variation 08: BuildKit NuGet cache mount
# Complexity: MEDIUM-HIGH
# NuGet packages cache is preserved between builds on the same host.

FROM mcr.microsoft.com/dotnet/sdk:8.0

ENV DOTNET_CLI_TELEMETRY_OPTOUT=1 \
    NUGET_PACKAGES=/nuget-cache

WORKDIR /dotnetv3

COPY ./dotnetv3/SES/ ./SES/

RUN --mount=type=cache,target=/nuget-cache \
    cd SES && dotnet restore && dotnet build -c Release

CMD ["bash"]
