# syntax=docker/dockerfile:1
# Variation 14: Read-only filesystem + non-root
# Complexity: HIGH

FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build

WORKDIR /src

COPY ./dotnetv3/SES/ ./SES/

RUN cd SES && dotnet restore && dotnet publish -c Release -o /app/publish

# ---- Runtime ----
FROM mcr.microsoft.com/dotnet/aspnet:8.0

RUN groupadd -r dotnetgroup && useradd -r -g dotnetgroup -m dotnetuser

WORKDIR /app

COPY --from=build --chown=dotnetuser:dotnetgroup /app/publish .

USER dotnetuser

ENV ASPNETCORE_URLS=http://+:8080 \
    DOTNET_CLI_TELEMETRY_OPTOUT=1

EXPOSE 8080

VOLUME ["/tmp"]

ENTRYPOINT ["dotnet", "SESV2_Lambda_Example.dll"]
